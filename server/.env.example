# Server Configuration
PORT=3000
NODE_ENV=development
# Render production value should be: NODE_ENV=production
# Comma-separated whitelist of allowed web origins (no trailing slash)
# Examples:
# - local only: CORS_ORIGIN=http://localhost:5173
# - local + production: CORS_ORIGIN=http://localhost:5173,https://your-client.onrender.com
CORS_ORIGIN=http://localhost:5173

# PostgreSQL Database Configuration (Render/Neon/local)
# Use your provider connection string, e.g. Render or Neon
DATABASE_URL=postgresql://username:password@hostname.provider.com/databasename
# Optional SSL overrides:
# - Leave unset for auto-detection (recommended)
# - Set DB_SSL=false for local non-SSL PostgreSQL
# - Set DB_SSL=true to force SSL
DB_SSL=true
# - Set true only if your provider requires cert verification
DB_SSL_REJECT_UNAUTHORIZED=false

# JWT Configuration
# IMPORTANT: Generate a strong random secret (min 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security Notes:
# - Generate a strong random JWT_SECRET (minimum 32 characters)
# - Never commit .env file with real credentials
# - Use different secrets for development and production
# - Rotate JWT_SECRET periodically in production
